{
	"name": "kenketsu-plus",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build"
	},
	"dependencies": {
		"next": "^15.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"leaflet": "^1.9.4",
		"react-leaflet": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/leaflet": "^1.9.12",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitest/coverage-v8": "^2.1.0",
		"oxlint": "^0.12.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0",
		"@testing-library/react": "^16.0.0",
		"@testing-library/jest-dom": "^6.6.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
