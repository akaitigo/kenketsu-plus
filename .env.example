# API
PORT=8080

# ストレージ切り替え (memory | postgres)
# デフォルト: memory (開発用インメモリ)
STORAGE=memory

# PostgreSQL接続 (STORAGE=postgres の場合に必須)
DATABASE_URL=postgres://user:password@localhost:5432/kenketsu_plus?sslmode=disable

# CORS (C-1)
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Notify API authentication (C-2: required in production)
NOTIFY_SECRET=change-me-in-production

# Admin API key for write endpoints (C-3: 必須。未設定時は管理APIが503で拒否される)
ADMIN_API_KEY=change-me-in-production

# WebPush VAPID keys
# 生成方法: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
