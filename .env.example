# API
PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/kenketsu_plus?sslmode=disable

# CORS (C-1)
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Notify API authentication (C-2: required in production)
NOTIFY_SECRET=change-me-in-production

# Admin API key for write endpoints (C-3: required in production)
ADMIN_API_KEY=change-me-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# Push Notifications (VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
